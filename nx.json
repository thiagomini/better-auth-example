{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "continuous": true
    },
    "start": {
      "cache": false,
      "continuous": true
    },
    "test": {
      "cache": true
    },
    "migrate": {
      "cache": true
    }
  },
  "defaultBase": "master",
  "analytics": false
}
